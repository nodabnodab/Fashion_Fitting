# API 키 설정 (이 파일을 .env로 복사하고 실제 키를 입력하세요)

# Gemini API 키 (https://aistudio.google.com/ 에서 무료 발급)
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace 토큰 (비공개 모델 다운로드 시 필요, https://huggingface.co/settings/tokens)
HF_TOKEN=your_huggingface_token_here

# 기본 모델 경로 설정
BASE_MODEL_PATH=models/base
LORA_PATH=models/lora
CONTROLNET_PATH=models/controlnet

# 출력 설정
OUTPUT_DIR=data/results
MAX_IMAGE_SIZE=1024
